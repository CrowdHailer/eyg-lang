let {assert} = import "../aok/index.eyg"
let {list, list_files, read, read_range, write} = import "./index.eyg"

let ignore = [".git", "node_modules", "build"]

// Whole-list helpers used by several tests below.
let files = (_) -> { list_files({root: ".", ignore}) }
let all_items = (_) -> { list({root: ".", ignore}) }

let has_path = (items, target) -> {
  !list_fold(items, False({}), ({type: _, path}, acc) -> {
    match !equal(path, target) {
      True(_) -> { True({}) }
      False(_) -> { acc }
    }
  })
}

let is_file = (items, target) -> {
  !list_fold(items, False({}), ({type, path}, acc) -> {
    match !equal(path, target) {
      True(_) -> {
        match type {
          File(_) -> { True({}) }
          Directory(_) -> { False({}) }
        }
      }
      False(_) -> { acc }
    }
  })
}

[
  {name: "fs list_files finds entry.eyg in the root directory",
   test: (_) -> { assert.contains(files({}), "entry.eyg") }},

  {name: "fs list_files respects the ignore list (.git)",
   test: (_) -> { assert.false(!list_fold(files({}), False({}), (p, acc) -> {
     match !equal(p, ".git/config") {
       True(_) -> { True({}) }
       False(_) -> { acc }
     }
   })) }},

  {name: "fs list returns structured records containing entry.eyg",
   test: (_) -> { assert.true(has_path(all_items({}), "entry.eyg")) }},

  {name: "fs list identifies entry.eyg as a File",
   test: (_) -> { assert.true(is_file(all_items({}), "entry.eyg")) }}
]
