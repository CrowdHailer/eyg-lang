// Each test mirrors one fixture from spec/ir_suite.json. 

let aok = import "../../aok/index.eyg"
let ast = import "../ast.eyg"
let cid = import "../cid.eyg"

// The json is the compact DAG JSON; the expected CID is the suite CID
// and nodes is the flat AST representation in EYG.
let check = (json, nodes, expected_cid) -> {
  let decoded = aok.ok(ast.source_json_to_ast(json))
  let _ = aok.equal(decoded, nodes)
  let decoded_bytes = aok.ok(ast.source_json_bytes_to_ast(!string_to_binary(json)))
  let _ = aok.equal(decoded_bytes, nodes)
  let rendered = ast.ast_to_string(decoded)
  let _ = aok.equal_string(rendered, json)
  let digest = perform Hash({algorithm: SHA256({}), bytes: !string_to_binary(rendered)})
  let _ = aok.equal_string(cid.from_sha256(digest), expected_cid)
  {}
}

let list_cid = "baguqeeraqyvjt4lhfr66jw66yhg37xaj7tvdde5pifx7eqdq2a4zgzpffwaq"

let test_variable = (_) -> {
  check(
    "{\"0\":\"v\",\"l\":\"foo\"}",
    [Variable("foo")],
    "baguqeera22cbouedtv3bzhajvp66ib6ichytfrid6osjpskyzthoivta6yyq"
  )
}

let test_function = (_) -> {
  check(
    "{\"0\":\"f\",\"b\":{\"0\":\"v\",\"l\":\"x\"},\"l\":\"x\"}",
    [Lambda("x"), Variable("x")],
    "baguqeeraup4cqhkgfpykg5bluntkz5q7vs5nmdhru2wlrtylf3bgqvpeog2q"
  )
}

let test_apply = (_) -> {
  check(
    "{\"0\":\"a\",\"a\":{\"0\":\"s\",\"v\":\"foo\"},\"f\":{\"0\":\"f\",\"b\":{\"0\":\"v\",\"l\":\"x\"},\"l\":\"x\"}}",
    [Apply({}), Lambda("x"), Variable("x"), String("foo")],
    "baguqeerah3rk6276thsyqacdce6o346jwset5vxsdrwwrek7n745vl5i2bma"
  )
}

let test_let = (_) -> {
  check(
    "{\"0\":\"l\",\"l\":\"x\",\"t\":{\"0\":\"v\",\"l\":\"x\"},\"v\":{\"0\":\"s\",\"v\":\"hi\"}}",
    [Let("x"), String("hi"), Variable("x")],
    "baguqeeraijyrkjvaioixrfdxtpbuhq6h2oqfu33jtuioehjghlqye27uoziq"
  )
}

let test_binary = (_) -> {
  check(
    "{\"0\":\"x\",\"v\":{\"/\":{\"bytes\":\"AQ\"}}}",
