[
  {name: "ast ir suite variable", test: test_variable},
  {name: "ast ir suite function", test: test_function},
  {name: "ast ir suite apply", test: test_apply},
  {name: "ast ir suite let", test: test_let},
  {name: "ast ir suite binary", test: test_binary},
  {name: "ast ir suite integer", test: test_integer},
  {name: "ast ir suite string", test: test_string},
  {name: "ast ir suite empty list", test: test_empty_list},
