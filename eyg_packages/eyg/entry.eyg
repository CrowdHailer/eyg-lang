let aok = import "../aok/index.eyg"
let tests = @standard.list.flatten([
  import "./test/base32_test.eyg",
  import "./test/cid_test.eyg",
  import "./test/json_test.eyg"
])

{
  tests: tests,
  script: (_) -> {
    match !equal(aok.all(tests).failed, 0) {
      True({}) -> { 0 }
      False({}) -> { 1 }
    }
  }
}