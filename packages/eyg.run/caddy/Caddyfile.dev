{$EYG_AUTHORITY} {
	handle /modules/* {
		reverse_proxy backend:8080
	}
	handle /packages/* {
		reverse_proxy backend:8080
	}
	handle /proxy/* {
		reverse_proxy backend:8080
	}
	handle /signatories/* {
		reverse_proxy backend:8080
	}

	handle {
		reverse_proxy frontend:8080
	}

  log {
		output stdout
		format console
		level {$LOG_LEVEL:INFO}
	}
}

